@{
    ViewData["Title"] = "تواصل معنا";
}

<main class="site-shell">
    <partial name="_SiteHeader" />

    <section class="section-block">
        <div class="section-heading">
            <span class="tag">Contact</span>
            <h2>تواصل معنا</h2>
        </div>

        <form id="contact-form" class="contact-form" novalidate>
            <label for="contact-name">الاسم</label>
            <input id="contact-name" name="contactName" type="text" placeholder="اكتب اسمك" />
            <small class="field-error" data-error-for="contactName"></small>

            <label for="contact-email">البريد الإلكتروني</label>
            <input
                id="contact-email"
                name="contactEmail"
                type="email"
                placeholder="name@example.com" />
            <small class="field-error" data-error-for="contactEmail"></small>

            <label for="contact-message">الرسالة</label>
            <textarea
                id="contact-message"
                name="contactMessage"
                rows="6"
                placeholder="اكتب رسالتك هنا"></textarea>
            <small class="field-error" data-error-for="contactMessage"></small>

            <button type="submit" class="primary-button">إرسال الرسالة</button>
        </form>

        <p id="contact-form-message" class="form-message" aria-live="polite"></p>
    </section>
</main>

@section Scripts {
    <script src="~/js/contact-page.js" asp-append-version="true"></script>
}
