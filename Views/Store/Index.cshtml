@{
    ViewData["Title"] = "الصفحة الرئيسية";
}

<main class="site-shell">
    <partial name="_SiteHeader" />

    <section class="hero-section">
        <div class="hero-copy">
            <span class="eyebrow">New Season, New Energy</span>
            <h1>هلبسك بإطلالة تعبر عنك من أول نظرة</h1>
            <p>
                اكتشف تشكيلة ملابس عصرية تجمع بين الراحة والتفاصيل الأنيقة، مصممة
                لتناسب يومك من الصباح لحد آخر خروجة.
            </p>
            <p>
                تصفح أقسام البناطيل والجاكيتات والتيشيرتات، واكتشف تشكيلات جديدة
                تناسب الستايل اليومي والخروجات.
            </p>

            <div class="hero-actions category-actions">
                <a class="primary-button link-button compact-button" asp-controller="Store" asp-action="Pants">بنطلون</a>
                <a class="primary-button link-button compact-button" asp-controller="Store" asp-action="Tshirt">تيشيرت</a>
                <a class="primary-button link-button compact-button" asp-controller="Store" asp-action="Jacket">جاكيت</a>
            </div>

            <div class="hero-stats">
                <div class="stat-card">
                    <strong>+1500</strong>
                    <span>عميل سعيد</span>
                </div>
                <div class="stat-card">
                    <strong>48h</strong>
                    <span>توصيل سريع</span>
                </div>
                <div class="stat-card">
                    <strong>2026</strong>
                    <span>أحدث الإصدارات</span>
                </div>
            </div>
        </div>

        <div class="hero-visual">
            <div class="visual-card main-visual">
                <span class="eyebrow">Featured Drop</span>
                <h2>New Pants Collection</h2>
                <p>خامات خفيفة، ألوان هادئة، وقصة تمنحك حضورًا واضحًا.</p>
            </div>

            <div class="floating-note top-note">
                <span>Members Save</span>
                <strong>خصم 20% لأول طلب</strong>
            </div>
        </div>
    </section>

    <section class="section-block" id="pants">
        <div class="section-heading">
            <span class="tag">Pants</span>
            <h2>البناطيل</h2>
        </div>

        <div class="collection-grid">
            <article class="collection-card">
                <span class="collection-label">Classic Fit</span>
                <h3>بنطلون كاجوال بيج</h3>
                <p>ستايل يومي مريح وسهل التنسيق مع أغلب الإطلالات.</p>
            </article>

            <article class="collection-card">
                <span class="collection-label">Relaxed Fit</span>
                <h3>بنطلون أوفر سايز أسود</h3>
                <p>قصة أوسع ولمسة streetwear عصرية.</p>
            </article>

            <article class="collection-card accent-card">
                <span class="collection-label">Limited Drop</span>
                <h3>بنطلون لينن صيفي</h3>
                <p>خامة خفيفة ومظهر أنيق للأيام الدافئة.</p>
            </article>
        </div>
    </section>

    <section class="section-block" id="jacket">
        <div class="section-heading">
            <span class="tag">Jackets</span>
            <h2>الجاكيتات</h2>
        </div>

        <div class="collection-grid">
            <article class="collection-card">
                <span class="collection-label">Light Layer</span>
                <h3>جاكيت خفيف أسود</h3>
                <p>مثالي للخروجات والمظهر الأنيق السريع.</p>
            </article>

            <article class="collection-card">
                <span class="collection-label">Urban Style</span>
                <h3>جاكيت دنيم أزرق</h3>
                <p>قطعة أساسية لستايل كاجوال جريء.</p>
            </article>

            <article class="collection-card accent-card">
                <span class="collection-label">Premium Pick</span>
                <h3>جاكيت أوفر سايز بني</h3>
                <p>تصميم مميز بخطوط واضحة ولمسة فخمة.</p>
            </article>
        </div>
    </section>

    <section class="section-block" id="tshirt">
        <div class="section-heading">
            <span class="tag">T-Shirts</span>
            <h2>التيشيرتات</h2>
        </div>

        <div class="collection-grid">
            <article class="collection-card">
                <span class="collection-label">Essential</span>
                <h3>تيشيرت أبيض أوفر سايز</h3>
                <p>قطعة أساسية بسيطة وسهلة مع أي لبس.</p>
            </article>

            <article class="collection-card">
                <span class="collection-label">Minimal</span>
                <h3>تيشيرت أسود سادة</h3>
                <p>ستايل نظيف ولمسة عصرية مناسبة يوميًا.</p>
            </article>

            <article class="collection-card accent-card">
                <span class="collection-label">New Drop</span>
                <h3>تيشيرت مطبوع Limited</h3>
                <p>تصميم مميز لعشاق القطع المختلفة.</p>
            </article>
        </div>
    </section>

    <section class="section-block" id="location">
        <div class="section-heading">
            <h2>موقعنا</h2>
        </div>

        <p style="text-align:center; margin-bottom:15px;">
            بالقرب من الجامعة الكندية - مدينة 6 أكتوبر
        </p>

        <div style="width:100%; height:400px; border-radius:15px; overflow:hidden;">
            <iframe
                src="https://www.google.com/maps/embed?pb=!1m18!1m12!1m3!1d3457.5033940130993!2d30.881093175340553!3d29.93619587497829!2m3!1f0!2f0!3f0!3m2!1i1024!2i768!4f13.1!3m3!1m2!1s0x1458ff685d274299%3A0x473b69afaee3c5b7!2sAhram%20Canadian%20University!5e0!3m2!1sen!2seg!4v1776903175727!5m2!1sen!2seg"
                width="100%"
                height="100%"
                style="border:0;"
                allowfullscreen=""
                loading="lazy">
            </iframe>
        </div>
    </section>
</main>
